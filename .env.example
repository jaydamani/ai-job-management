# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://gappeo:gappeo@localhost:5432/gappeo

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-secret

# ── AI (LiteLLM) ────────────────────────────────────────────────
AI_MODEL=gemini/gemini-flash-lite-latest
GEMINI_API_KEY=AIza...
# OPENAI_API_KEY=sk-...           # use with AI_MODEL=gpt-4o (etc.)

# ── Storage (MinIO locally / S3 or Cloudflare R2 in production) ──────────────
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET=gappeo
S3_ENDPOINT_URL=http://minio:9000          # MinIO internal URL (used by backend container)
MINIO_PUBLIC_URL=http://localhost:9000     # MinIO public URL (used in presigned URLs for browser)
                                            # Leave empty in production (uses real AWS/R2 endpoint)

# ── CORS ──────────────────────────────────────────────────────────────────────
# Docker Compose: leave empty (Nginx handles single-origin)
# Local dev: http://localhost:5173 (Vite dev server)
# Render: https://your-frontend.onrender.com
CORS_ORIGINS=http://localhost:5173

# ── Frontend (baked in at build time) ────────────────────────────────────────
# Local dev / Docker Compose: leave empty (relative URLs via Vite proxy or Nginx)
# Render static site: https://your-backend.onrender.com
VITE_API_URL=
